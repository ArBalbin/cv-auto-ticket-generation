APP_ENV=production
API_HOST=0.0.0.0
# Most cloud hosts inject PORT automatically. Use API_PORT only for local/manual runs.
API_PORT=5000

# Public backend URL used in generated ticket QR codes.
PORTAL_BASE_URL=https://your-queueflow-domain.example

# Browser frontend origins allowed to call this API.
# Add your hosted mobile/web frontend origin if it is separate from PORTAL_BASE_URL.
CORS_ORIGINS=https://your-queueflow-domain.example
TRUSTED_HOSTS=your-queueflow-domain.example
FORWARDED_ALLOW_IPS=*

# Required in production. Generate strong random values before deployment.
JWT_SECRET_KEY=replace-with-a-long-random-secret
CAM_TOKEN=replace-with-a-long-random-camera-token

# Secure cookie defaults for HTTPS cloud deployment.
SESSION_COOKIE_NAME=session_token
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=28800

# Staff account registration.
# In production, keep registration protected with a code or disable it after setup.
STAFF_REGISTRATION_ENABLED=1
STAFF_REGISTRATION_CODE=replace-with-a-staff-registration-code

# Database values are intentionally placeholders; configure your own cloud MySQL.
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=Crowd_Detection
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
# Use REQUIRED for Aiven or other cloud MySQL services that require TLS.
# Use VERIFY_CA / VERIFY_IDENTITY with DB_SSL_CA if you also configure the CA certificate.
DB_SSL_MODE=REQUIRED
DB_SSL_CA=

# Optional Redis cache/session/snapshot bridge.
REDIS_URL=
CACHE_KEY_PREFIX=queueflow
CACHE_STATE_TTL_SECONDS=30
CACHE_SNAPSHOT_TTL_SECONDS=10
CACHE_HISTORY_TTL_SECONDS=3600
REDIS_SOCKET_TIMEOUT=0.25
REDIS_CONNECT_TIMEOUT=0.25

# Optional S3-compatible ticket PDF storage.
# Leave disabled for local PDF-only testing.
OBJECT_STORAGE_ENABLED=0
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PREFIX=tickets
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_ADDRESSING_STYLE=auto

# Queue prediction defaults.
AVG_SERVICE_TIME=3.0
NUM_COUNTERS=3

# Detector settings for the computer that owns the camera.
# Set API_BASE_URL to your cloud URL on the detector machine.
API_BASE_URL=https://your-queueflow-domain.example
CAM_WIDTH=640
CAM_HEIGHT=480
FRAME_SCALE=1.00
YOLO_IMGSZ=320
YOLO_EVERY=8
JPEG_QUALITY=50
SNAPSHOT_FPS=12
PUSH_TIMEOUT=1.0
SNAPSHOT_TIMEOUT=0.8

# Generated ticket PDFs. Use persistent storage in production if you need to keep them.
TICKETS_OUTPUT_DIR=app/tickets
