# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
PORT=5000

# ── Public URL (your cloud domain — no trailing slash) ─────────────────────────
PORTAL_BASE_URL=https://your-app.onrender.com
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-app.onrender.com

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-64-char-random-hex
SECRET_KEY=replace-with-64-char-random-hex
CAM_TOKEN=replace-with-strong-random-token
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=lax

# ── Staff registration ─────────────────────────────────────────────────────────
STAFF_REGISTRATION_ENABLED=1
STAFF_REGISTRATION_CODE=replace-with-registration-code

# ── Database (Aiven MySQL) ─────────────────────────────────────────────────────
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=10885
DB_NAME=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=your-aiven-password
DB_SSL_MODE=REQUIRED

# ── Object storage (Supabase S3) ───────────────────────────────────────────────
OBJECT_STORAGE_ENABLED=1
OBJECT_STORAGE_ENDPOINT_URL=https://your-project.storage.supabase.co/storage/v1/s3
OBJECT_STORAGE_BUCKET=queueflow-tickets
OBJECT_STORAGE_REGION=ap-southeast-2
OBJECT_STORAGE_ACCESS_KEY_ID=your-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=your-secret-key
OBJECT_STORAGE_PREFIX=tickets
OBJECT_STORAGE_ADDRESSING_STYLE=path

# ── Detector → API (set this on the laptop running the detector) ───────────────
# API_BASE_URL=https://your-app.onrender.com

# ── Optional Redis cache ────────────────────────────────────────────────────────
# REDIS_URL=redis://default:password@your-redis-host:6379/0
